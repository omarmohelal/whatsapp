# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000
DASHBOARD_ORIGIN=http://localhost:3001
CDN_BASE_URL=https://cdn.example.com/thenexus

# Database / queues
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thenexus_agent?schema=public
REDIS_URL=redis://localhost:6379

# Admin
ADMIN_API_KEY=replace-with-long-random-admin-key
ADMIN_NOTIFICATION_NUMBER=201000000000

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-permanent-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_API_VERSION=v21.0
META_APP_SECRET=

# Messenger Platform (optional)
MESSENGER_VERIFY_TOKEN=replace-with-messenger-webhook-verify-token
MESSENGER_PAGE_ACCESS_TOKEN=replace-with-page-access-token

# Google Gemini
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Security
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-32-byte-base64-key
SENSITIVE_DATA_TTL_DAYS=7
SECURE_FORM_URL=https://www.thenexus.ink/
