{
  "name": "thenexus-whatsapp-ai-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade WhatsApp Business AI support and sales agent for TheNexus.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/jobs/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "worker": "node dist/src/jobs/worker.js",
    "test": "jest --runInBand",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "seed": "tsx src/scripts/seed.ts",
    "seed:prod": "node dist/src/scripts/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.21.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "openai": "^4.71.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  },
  "prisma": {
    "seed": "tsx src/scripts/seed.ts"
  }
}
